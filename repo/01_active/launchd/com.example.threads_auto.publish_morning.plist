<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.example.threads_auto.publish_morning</string>

    <key>ProgramArguments</key>
    <array>
        <string>__REPO_ROOT__/.venv/bin/python3</string>
        <string>__REPO_ROOT__/repo/01_active/scripts/publish.py</string>
        <string>--slot</string>
        <string>morning</string>
        <string>--profile</string>
        <string>production</string>
        <string>--randomize</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>WorkingDirectory</key>
    <string>__REPO_ROOT__/repo/01_active</string>

    <key>StandardOutPath</key>
    <string>__REPO_ROOT__/repo/01_active/logs/launchd-publish-morning.out</string>

    <key>StandardErrorPath</key>
    <string>__REPO_ROOT__/repo/01_active/logs/launchd-publish-morning.err</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__USER_LOCAL_BIN__:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>__HOME__</string>
        <key>LANG</key>
        <string>ja_JP.UTF-8</string>
        <key>LC_ALL</key>
        <string>ja_JP.UTF-8</string>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
