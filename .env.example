# ===== Discord =====
# generate.sh / publish.py の通知用 Webhook
DISCORD_WEBHOOK_URL=

# Bot が受け付けるチャンネル ID（4 種）
# 承認 / 修正フロー（#threads_auto 相当）
DISCORD_APPROVAL_CHANNEL_ID=
# 改善案バックログ収集（#threads_auto_backlog 相当）
DISCORD_BACKLOG_CHANNEL_ID=
# ネタ・ドラフト収集（#threads_auto_drafts 相当）
DISCORD_DRAFTS_CHANNEL_ID=
# /予約確認 等の照会専用チャンネル
DISCORD_STATUS_CHANNEL_ID=

# Bot のオーナー（このユーザー以外の DM / メッセージは無視する）
DISCORD_OWNER_USER_ID=
